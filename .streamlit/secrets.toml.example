# Streamlit secrets — copy this file to .streamlit/secrets.toml
# and fill in your actual Vercel deployment URL.
#
# On Streamlit Community Cloud:
#   Go to App Settings -> Secrets and paste the key=value lines below.
#
# Locally:
#   Copy to .streamlit/secrets.toml (already in .gitignore)
#   and the app will call your Vercel API instead of the local model.

API_URL = "https://your-project.vercel.app"
